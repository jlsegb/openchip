APP_ENV=development
PORT=8080
LOG_LEVEL=info
DISABLE_EMAIL=true
DATABASE_URL=postgres://openchip:openchip@postgres:5432/openchip?sslmode=disable
JWT_SECRET=replace-with-a-long-random-secret
RESEND_API_KEY=
FROM_EMAIL=noreply@openchip.org
ADMIN_EMAIL=admin@openchip.org
SUPPORT_EMAIL=support@openchip.org
BASE_URL=http://localhost:3000
SHELTER_API_KEYS=local-shelter-key:Example Shelter
TRUSTED_PROXY_CIDRS=127.0.0.1/32,::1/128
RATE_LIMIT_LOOKUP_PER_MIN=60
RATE_LIMIT_AUTH_PER_MIN=5
MIGRATIONS_PATH=file:///app/db/migrations
SEED_MIGRATIONS_PATH=file:///app/db/seeds
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1
